@model QLSanBong.MVC.Models.CreateUpdateServiceViewModel
@using QLSanBong.Domain.Enums

@{
    ViewData["Title"] = "Cập Nhật Mặt Hàng";
}

@section Styles {
    <style>
        .form-control:focus, .form-select:focus {
            border-color: #ffc107;
            box-shadow: 0 0 0 0.25rem rgba(255, 193, 7, 0.25);
        }
    </style>
}

<div class="container-fluid mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-9 col-lg-7">
            <div class="d-flex align-items-center mb-4">
                <a asp-action="Index" class="btn btn-outline-secondary rounded-circle me-3 shadow-sm" style="width: 42px; height: 42px; display: flex; align-items: center; justify-content: center;">
                    <i class="bi bi-arrow-left"></i>
                </a>
                <div>
                    <h3 class="text-dark fw-bold mb-0">Cập Nhật Thông Tin</h3>
                    <p class="text-muted mb-0 small">Chỉnh sửa thông tin mặt hàng đang chọn</p>
                </div>
            </div>

            <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
                <div class="card-header bg-gradient-warning py-3 border-0" style="background: linear-gradient(135deg, #ffc107 0%, #ffca2c 100%);">
                    <h5 class="mb-0 fw-bold text-dark"><i class="bi bi-pencil-square me-2"></i>Sửa Đổi Sản Phẩm</h5>
                </div>
                <div class="card-body p-4 p-md-5 bg-white">
                    <form asp-action="Save" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger fw-bold rounded-3 shadow-sm"></div>

                        <input type="hidden" asp-for="Id" />

                        <div class="mb-4">
                            <label asp-for="Name" class="form-label fw-bold text-secondary">Tên Mặt Hàng <span class="text-danger">*</span></label>
                            <input asp-for="Name" class="form-control form-control-lg bg-light border-0" required />
                            <span asp-validation-for="Name" class="text-danger small fw-bold"></span>
                        </div>

                        <div class="row mb-4">
                            <div class="col-md-6 mb-4 mb-md-0">
                                <label asp-for="Category" class="form-label fw-bold text-secondary">Phân Loại <span class="text-danger">*</span></label>
                                <select asp-for="Category" asp-items="Html.GetEnumSelectList<ServiceCategory>()" class="form-select form-select-lg bg-light border-0 cursor-pointer" required></select>
                                <span asp-validation-for="Category" class="text-danger small fw-bold"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Unit" class="form-label fw-bold text-secondary">Đơn Vị Tính <span class="text-danger">*</span></label>
                                <input asp-for="Unit" class="form-control form-control-lg bg-light border-0" required />
                                <span asp-validation-for="Unit" class="text-danger small fw-bold"></span>
                            </div>
                        </div>

                        <div class="mb-5">
                            <label asp-for="Price" class="form-label fw-bold text-secondary">Đơn Giá Bán (VNĐ) <span class="text-danger">*</span></label>
                            <div class="input-group input-group-lg shadow-sm rounded-3 overflow-hidden">
                                <span class="input-group-text bg-white border-0 text-warning"><i class="bi bi-cash-stack"></i></span>
                                <input asp-for="Price" type="number" class="form-control bg-light border-0" required />
                                <span class="input-group-text bg-light border-0 text-muted fw-bold">đ</span>
                            </div>
                            <span asp-validation-for="Price" class="text-danger small fw-bold"></span>
                        </div>

                        <div class="d-flex flex-column flex-sm-row gap-3 mt-2">
                            <button type="submit" class="btn btn-warning btn-lg fw-bold flex-grow-1 text-dark rounded-pill shadow-sm py-3">
                                <i class="bi bi-check-circle me-2"></i> LƯU THAY ĐỔI
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}