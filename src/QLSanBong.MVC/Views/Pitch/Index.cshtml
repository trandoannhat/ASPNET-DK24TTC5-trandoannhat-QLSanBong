@model IEnumerable<QLSanBong.MVC.Models.PitchViewModel>
@{
    ViewData["Title"] = "Danh Sách Sân Bóng";
}

@section Styles {
    <style>
        /* Hiệu ứng mượt mà cho thẻ sân bóng */
        .pitch-card {
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            border-radius: 1rem;
        }

            .pitch-card:hover {
                transform: translateY(-8px);
                box-shadow: 0 15px 30px rgba(0,0,0,0.1) !important;
            }

        /* Khung chứa ảnh để khi ảnh phóng to không bị tràn ra ngoài viền bo góc */
        .img-wrapper {
            overflow: hidden;
            border-top-left-radius: 1rem;
            border-top-right-radius: 1rem;
        }

        /* Hiệu ứng zoom nhẹ ảnh khi di chuột vào thẻ */
        .pitch-card .card-img-top {
            transition: transform 0.5s ease;
        }

        .pitch-card:hover .card-img-top {
            transform: scale(1.08);
        }
    </style>
}

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-uppercase text-success mb-0">
            <i class="bi bi-ui-checks-grid me-2"></i>Danh Sách Sân Bóng
        </h2>
        <a asp-action="Create" class="btn btn-primary fw-bold shadow-sm rounded-pill px-4">
            <i class="bi bi-plus-circle me-1"></i> Thêm Sân Mới
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm rounded-3 border-0" role="alert">
            <i class="bi bi-check-circle-fill me-2 fs-5 align-middle"></i>
            <span class="align-middle">@TempData["SuccessMessage"]</span>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row g-4 mt-2">
        @if (Model != null && Model.Any())
        {
            // Link ảnh sân cỏ chuẩn để làm dự phòng (fallback)
            var defaultPitchImage = "https://images.unsplash.com/photo-1579952363873-27f3bade9f55?q=80&w=600&auto=format&fit=crop";

            @foreach (var pitch in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm border-0 pitch-card bg-white">
                        <div class="img-wrapper">
                            <img src="@(string.IsNullOrEmpty(pitch.ImageUrl) ? defaultPitchImage : pitch.ImageUrl)"
                                 class="card-img-top"
                                 alt="@pitch.Name"
                                 style="height: 240px; object-fit: cover;"
                                 onerror="this.onerror=null;this.src='@defaultPitchImage';">
                        </div>

                        <div class="card-body d-flex flex-column p-4">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <h5 class="card-title fw-bold text-dark mb-0 fs-4">@pitch.Name</h5>
                                <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 rounded-pill px-3 py-2 fw-bold">Sân @pitch.PitchType</span>
                            </div>

                            <div class="d-flex align-items-center mb-4">
                                <i class="bi bi-tag-fill text-success me-2"></i>
                                <h5 class="fw-bold text-success mb-0">@pitch.PricePerHour.ToString("N0") đ<small class="text-muted fw-normal fs-6">/giờ</small></h5>
                            </div>

                            <div class="mt-auto">
                                <a href="@Url.Action("Book", "Pitch", new { pitchId = pitch.Id })" class="btn btn-outline-success w-100 fw-bold py-2 rounded-3 shadow-sm d-flex justify-content-center align-items-center gap-2">
                                    <i class="bi bi-calendar-check"></i> Đặt Lịch Ngay
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center">
                <div class="alert alert-light py-5 shadow-sm rounded-4 border">
                    <i class="bi bi-inbox text-muted opacity-50" style="font-size: 4rem;"></i>
                    <h4 class="fw-bold mt-3 text-dark">Hệ thống chưa có sân bóng</h4>
                    <p class="text-muted mb-0 mt-2">Vui lòng click vào nút "Thêm Sân Mới" ở góc trên bên phải để bắt đầu.</p>
                </div>
            </div>
        }
    </div>
</div>