@model QLSanBong.MVC.Models.CreatePitchViewModel
@{
    ViewData["Title"] = "Thêm Sân Bóng Mới";
}

<div class="container mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="d-flex align-items-center mb-4">
                <a asp-action="Index" class="btn btn-outline-secondary rounded-circle me-3" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
                    <i class="bi bi-arrow-left"></i>
                </a>
                <h3 class="text-dark fw-bold mb-0">Thêm Sân Mới</h3>
            </div>

            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body p-4 p-md-5">
                    <form asp-action="Create" asp-controller="Pitch" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4 rounded-3"></div>

                        <div class="mb-4">
                            <label asp-for="Name" class="form-label fw-bold text-secondary">Tên sân bóng <span class="text-danger">*</span></label>
                            <input asp-for="Name" class="form-control form-control-lg bg-light border-0" placeholder="VD: Sân cỏ nhân tạo số 1" />
                            <span asp-validation-for="Name" class="text-danger small fw-bold"></span>
                        </div>

                        <div class="row mb-4">
                            <div class="col-md-6 mb-4 mb-md-0">
                                <label asp-for="PitchType" class="form-label fw-bold text-secondary">Quy mô sân</label>
                                <select asp-for="PitchType" class="form-select form-select-lg bg-light border-0 cursor-pointer">
                                    <option value="5">Sân 5 người</option>
                                    <option value="7">Sân 7 người</option>
                                    <option value="11">Sân 11 người (Sân lớn)</option>
                                </select>
                                <span asp-validation-for="PitchType" class="text-danger small fw-bold"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="PricePerHour" class="form-label fw-bold text-secondary">Giá thuê (VNĐ/Giờ) <span class="text-danger">*</span></label>
                                <div class="input-group input-group-lg">
                                    <input asp-for="PricePerHour" type="number" class="form-control bg-light border-0" placeholder="300000" />
                                    <span class="input-group-text bg-light border-0 text-muted fw-bold">đ</span>
                                </div>
                                <span asp-validation-for="PricePerHour" class="text-danger small fw-bold"></span>
                            </div>
                        </div>

                        <div class="mb-5">
                            <label asp-for="ImageUrl" class="form-label fw-bold text-secondary">Link ảnh minh họa (URL)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0"><i class="bi bi-link-45deg"></i></span>
                                <input asp-for="ImageUrl" class="form-control bg-light border-0" placeholder="https://..." />
                            </div>
                            <div class="form-text mt-2"><i class="bi bi-info-circle me-1"></i>Để trống hệ thống sẽ dùng ảnh sân cỏ mặc định.</div>
                            <span asp-validation-for="ImageUrl" class="text-danger small fw-bold"></span>
                        </div>

                        <button type="submit" class="btn btn-primary btn-lg w-100 fw-bold rounded-pill shadow-sm py-3">
                            <i class="bi bi-plus-circle-fill me-2"></i> LƯU SÂN BÓNG
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>