@model QLSanBong.MVC.Models.BookPitchViewModel

@{
    ViewData["Title"] = "Đặt Sân Online";
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <style>
        .input-group-text {
            background-color: transparent;
            border-right: none;
            color: #198754;
        }

        .form-control.with-icon {
            border-left: none;
        }

            .form-control.with-icon:focus {
                box-shadow: none;
                border-color: #dee2e6;
            }

        .input-group:focus-within {
            box-shadow: 0 0 0 0.25rem rgba(25, 135, 84, 0.25);
            border-radius: 0.5rem;
        }

        .payment-card {
            border: 2px solid #e9ecef;
            transition: all 0.2s ease;
        }

            .payment-card:hover {
                border-color: #a3cfbb;
                background-color: #f8f9fa;
            }

            .payment-card.active {
                border-color: #198754;
                background-color: #f8f9fa;
                box-shadow: 0 0.125rem 0.25rem rgba(25, 135, 84, 0.15);
            }
    </style>
}

<div class="container mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-xl-10 col-lg-11">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">

                <div class="card-header bg-gradient-success text-white py-3 px-4 d-flex flex-column flex-md-row justify-content-between align-items-center" style="background: linear-gradient(135deg, #198754 0%, #146c43 100%);">
                    <div>
                        <span class="badge bg-white text-success rounded-pill px-3 py-1 mb-2 fw-bold shadow-sm">BƯỚC CUỐI CÙNG</span>
                        <h4 class="mb-0 fw-bold text-uppercase"><i class="bi bi-geo-alt-fill text-warning me-2"></i> Xác Nhận Đặt Sân: @Model.PitchName</h4>
                    </div>
                    <div class="bg-white rounded-3 px-4 py-2 text-center mt-3 mt-md-0 shadow-sm">
                        <span class="text-secondary fw-bold small d-block">Đơn giá</span>
                        <span class="fs-4 fw-bold text-danger">@Model.PricePerHour.ToString("N0") đ<small class="text-muted fs-6">/giờ</small></span>
                    </div>
                </div>

                <div class="card-body p-4 p-md-5 bg-white">
                    <form asp-action="Book" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger fw-bold rounded-3 shadow-sm" role="alert"></div>

                        <input type="hidden" asp-for="PitchId" />
                        <input type="hidden" asp-for="PitchName" />
                        <input type="hidden" asp-for="PricePerHour" />

                        <div class="row g-5">

                            <div class="col-lg-7 border-end-lg pe-lg-4">

                                <h5 class="fw-bold mb-3 text-success border-bottom pb-2"><i class="bi bi-person-lines-fill me-2"></i>Thông Tin Liên Hệ</h5>
                                <div class="row g-3 mb-4">
                                    <div class="col-sm-6">
                                        <label asp-for="CustomerName" class="form-label fw-bold text-secondary small">Họ và tên <span class="text-danger">*</span></label>
                                        <div class="input-group border rounded-3 shadow-sm">
                                            <span class="input-group-text border-0"><i class="bi bi-person"></i></span>
                                            <input asp-for="CustomerName" class="form-control with-icon border-0" placeholder="Nguyễn Văn A" required />
                                        </div>
                                        <span asp-validation-for="CustomerName" class="text-danger small fw-bold"></span>
                                    </div>
                                    <div class="col-sm-6">
                                        <label asp-for="CustomerPhone" class="form-label fw-bold text-secondary small">Số điện thoại <span class="text-danger">*</span></label>
                                        <div class="input-group border rounded-3 shadow-sm">
                                            <span class="input-group-text border-0"><i class="bi bi-telephone"></i></span>
                                            <input asp-for="CustomerPhone" class="form-control with-icon border-0" placeholder="0901234567" required />
                                        </div>
                                        <span asp-validation-for="CustomerPhone" class="text-danger small fw-bold"></span>
                                    </div>
                                </div>

                                <h5 class="fw-bold mb-3 text-success border-bottom pb-2"><i class="bi bi-clock-history me-2"></i>Thời Gian Thi Đấu</h5>
                                <div class="mb-3">
                                    <label asp-for="BookingDate" class="form-label fw-bold text-secondary small">Ngày đá <span class="text-danger">*</span></label>
                                    <div class="input-group border rounded-3 shadow-sm">
                                        <span class="input-group-text border-0"><i class="bi bi-calendar-event"></i></span>
                                        <input asp-for="BookingDate" type="text" id="clientBookingDate" class="form-control with-icon border-0 bg-white" value='@Model.BookingDate.ToString("yyyy-MM-dd")' required />
                                    </div>
                                    <span asp-validation-for="BookingDate" class="text-danger small fw-bold"></span>
                                </div>
                                <div class="row g-3 mb-4">
                                    <div class="col-sm-6">
                                        <label asp-for="StartTime" class="form-label fw-bold text-secondary small">Giờ bắt đầu <span class="text-danger">*</span></label>
                                        <input asp-for="StartTime" type="time" class="form-control border rounded-3 shadow-sm" required />
                                        <span asp-validation-for="StartTime" class="text-danger small fw-bold"></span>
                                    </div>
                                    <div class="col-sm-6">
                                        <label asp-for="EndTime" class="form-label fw-bold text-secondary small">Giờ kết thúc <span class="text-danger">*</span></label>
                                        <input asp-for="EndTime" type="time" class="form-control border rounded-3 shadow-sm" required />
                                        <span asp-validation-for="EndTime" class="text-danger small fw-bold"></span>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="Notes" class="form-label fw-bold text-secondary small">Ghi chú (Tùy chọn)</label>
                                    <textarea asp-for="Notes" class="form-control border rounded-3 shadow-sm p-3" rows="2" placeholder="VD: Cần thuê 2 quả bóng..."></textarea>
                                </div>
                            </div>

                            <div class="col-lg-5 ps-lg-4 d-flex flex-column">

                                <h5 class="fw-bold mb-3 text-success border-bottom pb-2"><i class="bi bi-credit-card me-2"></i>Phương Thức Thanh Toán</h5>

                                <div class="d-flex flex-column gap-3 mb-4">
                                    <label class="payment-card active p-3 rounded-4 cursor-pointer d-flex align-items-center" for="payCash">
                                        <input class="form-check-input mt-0 me-3" type="radio" asp-for="PaymentMethod" value="Tiền mặt" id="payCash" checked onchange="togglePaymentStyle(this)">
                                        <div class="d-flex align-items-center w-100">
                                            <div class="bg-success bg-opacity-10 p-2 rounded-circle me-3">
                                                <i class="bi bi-cash text-success fs-3"></i>
                                            </div>
                                            <div>
                                                <h6 class="fw-bold mb-0">Thanh toán tại sân</h6>
                                                <small class="text-muted">Thanh toán trực tiếp sau trận</small>
                                            </div>
                                        </div>
                                    </label>

                                    <label class="payment-card p-3 rounded-4 cursor-pointer d-flex align-items-center" for="payVnPay">
                                        <input class="form-check-input mt-0 me-3" type="radio" asp-for="PaymentMethod" value="VNPay" id="payVnPay" onchange="togglePaymentStyle(this)">
                                        <div class="d-flex align-items-center w-100">
                                            <div class="bg-primary bg-opacity-10 p-2 rounded-circle me-3">
                                                <i class="bi bi-qr-code-scan text-primary fs-3"></i>
                                            </div>
                                            <div>
                                                <h6 class="fw-bold mb-0">Chuyển khoản VNPay</h6>
                                                <small class="text-muted">Cọc 30% duyệt tự động</small>
                                            </div>
                                        </div>
                                    </label>
                                </div>

                                <div class="mt-auto"></div>

                                <div class="d-flex flex-column gap-2 pt-3 border-top">
                                    <button type="submit" class="btn btn-success btn-lg w-100 fw-bold shadow rounded-pill btn-hover-scale py-3">
                                        <i class="bi bi-check-circle-fill me-2"></i> XÁC NHẬN ĐẶT SÂN
                                    </button>
                                    <a asp-controller="Home" asp-action="Index" class="btn btn-light btn-lg fw-bold rounded-pill shadow-sm border w-100">
                                        Hủy Bỏ
                                    </a>
                                </div>

                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/vn.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            flatpickr("#clientBookingDate", {
                locale: "vn",
                dateFormat: "Y-m-d",
                altInput: true,
                altFormat: "l, d/m/Y",
                minDate: "today",
                defaultDate: "@Model.BookingDate.ToString("yyyy-MM-dd")"
            });
        });

        function togglePaymentStyle(radio) {
            document.querySelectorAll('.payment-card').forEach(el => el.classList.remove('active'));
            radio.closest('.payment-card').classList.add('active');
        }
    </script>
    <style>
        /* CSS tự động thêm viền dọc khi ở màn hình máy tính (md trở lên) */
        @@media (min-width: 992px) {
            .border-end-lg {
                border-right: 1px solid #dee2e6 !important;
            }
        }
    </style>
}