@* Trang Đăng Nhập *@
@model QLSanBong.MVC.Models.LoginViewModel

@{
    ViewData["Title"] = "Đăng Nhập";
    // Lấy ReturnUrl từ QueryString nếu có
    var returnUrl = Context.Request.Query["ReturnUrl"];
}

<div class="row justify-content-center mt-5 mb-5">
    <div class="col-md-5">
        <div class="card shadow-sm border-0 rounded-3">
            <div class="card-body p-5">
                <h3 class="text-center fw-bold text-primary mb-4">Đăng Nhập</h3>

                <form asp-action="Login" asp-route-returnurl="@returnUrl" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3 fw-bold"></div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-semibold">Địa chỉ Email</label>
                        <input asp-for="Email" class="form-control form-control-lg" placeholder="name@example.com" required />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <div class="d-flex justify-content-between">
                            <label asp-for="Password" class="form-label fw-semibold">Mật khẩu</label>
                            <a href="#" class="text-decoration-none small text-muted">Quên mật khẩu?</a>
                        </div>
                        <input asp-for="Password" type="password" class="form-control form-control-lg" placeholder="Nhập mật khẩu" required />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="mb-4 form-check">
                        <input asp-for="RememberMe" class="form-check-input" />
                        <label asp-for="RememberMe" class="form-check-label text-muted">Ghi nhớ đăng nhập</label>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary btn-lg rounded-pill fw-bold">Đăng Nhập</button>
                    </div>
                </form>

                <div class="mt-4 text-center">
                    <p class="mb-0 text-muted">Chưa có tài khoản? <a asp-action="Register" asp-route-returnurl="@returnUrl" class="text-decoration-none fw-bold">Đăng ký ngay</a></p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}