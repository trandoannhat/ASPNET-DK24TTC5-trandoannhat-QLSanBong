@model QLSanBong.Application.DTOs.Dashboard.DashboardDto

@{
    ViewData["Title"] = "Dashboard Thống Kê";
}

@section Styles {
    <style>
        /* Hiệu ứng load trang  */
        .fade-in-up {
            animation: fadeInUp 0.6s ease-out forwards;
            opacity: 0;
            transform: translateY(15px);
        }

        /* Thêm @@ để Razor không hiểu nhầm là C# code */
        @@keyframes fadeInUp {
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Hiệu ứng hover nổi thẻ cho các card thống kê */
        .hover-elevate {
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

            .hover-elevate:hover {
                transform: translateY(-7px);
                box-shadow: 0 10px 20px rgba(0,0,0,0.15) !important;
            }

        /* Hiệu ứng nhấp nháy cho thông báo q */
        .badge-pulse {
            animation: pulse-red 1.5s infinite;
        }

        /* Thêm @@ để Razor không hiểu nhầm là C# code */
        @@keyframes pulse-red {
            0% {
                box-shadow: 0 0 0 0 rgba(220, 53, 69, 0.7);
            }

            70% {
                box-shadow: 0 0 0 6px rgba(220, 53, 69, 0);
            }

            100% {
                box-shadow: 0 0 0 0 rgba(220, 53, 69, 0);
            }
        }
    </style>
}

<div class="container-fluid mt-4 mb-5 fade-in-up">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
        <h2 class="fw-bold text-uppercase mb-0 text-dark" style="letter-spacing: -0.5px;">
            <i class="bi bi-grid-1x2-fill text-primary me-2"></i> Tổng Quan Kinh Doanh
        </h2>
        <div class="badge bg-light text-dark border p-2 shadow-sm fs-6">
            <i class="bi bi-clock-history text-primary me-1"></i> Cập nhật: @DateTime.Now.ToString("HH:mm - dd/MM/yyyy")
        </div>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm rounded-4 h-100 bg-gradient-primary text-white hover-elevate" style="background: linear-gradient(135deg, #0d6efd 0%, #0a58ca 100%);">
                <div class="card-body p-4 d-flex flex-column justify-content-between">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div>
                            <p class="mb-1 text-white-50 fw-bold text-uppercase" style="font-size: 0.85rem; letter-spacing: 0.5px;">Doanh thu Hôm nay</p>
                            <h3 class="fw-bold mb-0">@Model.RevenueToday.ToString("N0") đ</h3>
                        </div>
                        <div class="bg-white bg-opacity-25 p-3 rounded-circle d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                            <i class="bi bi-cash-stack fs-4"></i>
                        </div>
                    </div>
                    <div class="mt-auto border-top border-light border-opacity-25 pt-3">
                        <a asp-controller="AdminBooking" asp-action="Index" asp-route-filterDate="@DateTime.Today.ToString("yyyy-MM-dd")" asp-route-statusFilter="Hoàn" class="text-white fw-bold text-decoration-none small d-flex justify-content-between align-items-center stretched-link">
                            Xem các hóa đơn <i class="bi bi-arrow-right"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm rounded-4 h-100 bg-gradient-success text-white hover-elevate" style="background: linear-gradient(135deg, #20c997 0%, #198754 100%);">
                <div class="card-body p-4 d-flex flex-column justify-content-between">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div>
                            <p class="mb-1 text-white-50 fw-bold text-uppercase" style="font-size: 0.85rem; letter-spacing: 0.5px;">Doanh thu Tháng này</p>
                            <h3 class="fw-bold mb-0">@Model.RevenueThisMonth.ToString("N0") đ</h3>
                        </div>
                        <div class="bg-white bg-opacity-25 p-3 rounded-circle d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                            <i class="bi bi-wallet2 fs-4"></i>
                        </div>
                    </div>
                    <div class="mt-auto border-top border-light border-opacity-25 pt-3">
                        <a asp-controller="AdminBooking" asp-action="Index" asp-route-statusFilter="Hoàn" class="text-white fw-bold text-decoration-none small d-flex justify-content-between align-items-center stretched-link">
                            Xem chi tiết <i class="bi bi-arrow-right"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm rounded-4 h-100 bg-gradient-info text-white hover-elevate" style="background: linear-gradient(135deg, #0dcaf0 0%, #087990 100%);">
                <div class="card-body p-4 d-flex flex-column justify-content-between">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div>
                            <p class="mb-1 text-white-50 fw-bold text-uppercase" style="font-size: 0.85rem; letter-spacing: 0.5px;">Số Ca Đá Hôm Nay</p>
                            <h3 class="fw-bold mb-0">@Model.TotalBookingsToday <span class="fs-6 fw-normal opacity-75">ca</span></h3>
                        </div>
                        <div class="bg-white bg-opacity-25 p-3 rounded-circle d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                            <i class="bi bi-dribbble fs-4"></i>
                        </div>
                    </div>
                    <div class="mt-auto border-top border-light border-opacity-25 pt-3">
                        <a asp-controller="AdminBooking" asp-action="Index" asp-route-filterDate="@DateTime.Today.ToString("yyyy-MM-dd")" class="text-white fw-bold text-decoration-none small d-flex justify-content-between align-items-center stretched-link">
                            Xem lịch sân <i class="bi bi-arrow-right"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm rounded-4 h-100 text-dark hover-elevate" style="background: linear-gradient(135deg, #ffc107 0%, #fd7e14 100%);">
                <div class="card-body p-4 d-flex flex-column justify-content-between">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div>
                            <p class="mb-1 text-dark fw-bold text-uppercase" style="font-size: 0.85rem; letter-spacing: 0.5px; opacity: 0.6;">Lịch Chờ Duyệt</p>
                            <h3 class="fw-bold mb-0">@Model.PendingBookings <span class="fs-6 fw-normal opacity-75">lịch</span></h3>
                        </div>
                        <div class="bg-dark bg-opacity-10 p-3 rounded-circle d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                            <i class="bi bi-hourglass-split fs-4 text-dark"></i>
                        </div>
                    </div>
                    <div class="mt-auto border-top border-dark border-opacity-10 pt-3 z-index-1">
                        <a asp-controller="AdminBooking" asp-action="Index" asp-route-statusFilter="Chờ" class="text-dark fw-bold text-decoration-none small d-flex justify-content-between align-items-center position-relative">
                            Xử lý ngay
                            @if (Model.PendingBookings > 0)
                            {
                                <span class="badge bg-danger rounded-pill badge-pulse shadow-sm position-absolute" style="left: 70px;">Mới</span>
                            }
                            <i class="bi bi-arrow-right ms-auto"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row fade-in-up" style="animation-delay: 0.2s;">
        <div class="col-12">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-2 px-4">
                    <h5 class="fw-bold text-dark mb-0">
                        <span class="bg-primary bg-opacity-10 text-primary p-2 rounded-3 me-2">
                            <i class="bi bi-graph-up-arrow"></i>
                        </span>
                        Biểu đồ Doanh thu <span class="text-muted fs-6 fw-normal">(7 ngày gần nhất)</span>
                    </h5>
                </div>
                <div class="card-body p-4">
                    <div style="height: 380px; width: 100%;">
                        <canvas id="revenueChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Set font mặc định cho Chart.js để đồng bộ với UI hệ thống
            Chart.defaults.font.family = "'Segoe UI', 'Inter', -apple-system, sans-serif";
            Chart.defaults.color = '#6c757d';

            var labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DateLabels));
            var dataValues = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.RevenueData));

            var ctx = document.getElementById('revenueChart').getContext('2d');

            var gradient = ctx.createLinearGradient(0, 0, 0, 400);
            gradient.addColorStop(0, 'rgba(13, 110, 253, 0.4)');
            gradient.addColorStop(1, 'rgba(13, 110, 253, 0.0)');

            var revenueChart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Doanh thu',
                        data: dataValues,
                        backgroundColor: gradient,
                        borderColor: '#0d6efd',
                        borderWidth: 3,
                        pointBackgroundColor: '#ffffff',
                        pointBorderColor: '#0d6efd',
                        pointBorderWidth: 2,
                        pointRadius: 4,
                        pointHoverRadius: 6,
                        pointHoverBackgroundColor: '#0d6efd',
                        pointHoverBorderColor: '#ffffff',
                        fill: true,
                        tension: 0.4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    interaction: {
                        mode: 'index',
                        intersect: false,
                    },
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            backgroundColor: 'rgba(33, 37, 41, 0.9)',
                            titleFont: { size: 13, weight: 'bold' },
                            bodyFont: { size: 14 },
                            padding: 12,
                            cornerRadius: 8,
                            displayColors: false,
                            callbacks: {
                                label: function(context) {
                                    let value = context.parsed.y;
                                    return new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(value);
                                }
                            }
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            border: { display: false },
                            grid: {
                                color: 'rgba(0, 0, 0, 0.05)',
                                drawTicks: false,
                            },
                            ticks: {
                                padding: 10,
                                callback: function(value) {
                                    if(value >= 1000000) return (value / 1000000) + ' Tr';
                                    if(value >= 1000) return (value / 1000) + ' k';
                                    return value;
                                }
                            }
                        },
                        x: {
                            border: { display: false },
                            grid: { display: false },
                            ticks: { padding: 10 }
                        }
                    }
                }
            });
        });
    </script>
}