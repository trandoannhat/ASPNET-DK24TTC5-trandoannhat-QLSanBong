@model IEnumerable<QLSanBong.MVC.Models.BookingViewModel>
@{
    ViewData["Title"] = "Quản Lý Đặt Sân";
}

@section Styles {
    <style>
        .admin-table-row {
            transition: all 0.2s ease-in-out;
        }

            .admin-table-row:hover {
                background-color: #f8f9fa;
                transform: translateY(-2px);
                box-shadow: 0 4px 8px rgba(0,0,0,0.05);
            }
    </style>
}

<div class="container-fluid mt-4 mb-5">

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
        <h2 class="fw-bold text-uppercase mb-0 text-dark">
            <span class="bg-primary bg-opacity-10 text-primary p-2 rounded-3 me-2">
                <i class="bi bi-card-checklist"></i>
            </span>
            Quản Lý Ca Đá
        </h2>
        <button class="btn btn-success fw-bold shadow-sm rounded-pill px-4 py-2" data-bs-toggle="modal" data-bs-target="#quickBookModal">
            <i class="bi bi-lightning-charge-fill me-1"></i> Đặt Sân Nhanh
        </button>
    </div>

    <div class="card shadow-sm border-0 mb-4 bg-white rounded-4 overflow-hidden">
        <div class="card-body p-4 bg-light border-bottom">
            <form method="get" asp-action="Index" class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label fw-bold text-secondary small mb-2"><i class="bi bi-calendar-event text-primary me-1"></i> Ngày đặt</label>
                    <input type="date" name="filterDate" class="form-control form-control-lg border-0 shadow-sm" value="@ViewBag.FilterDate" />
                </div>

                <div class="col-md-3">
                    <label class="form-label fw-bold text-secondary small mb-2"><i class="bi bi-search text-success me-1"></i> Khách hàng / SĐT</label>
                    <input type="text" name="searchString" class="form-control form-control-lg border-0 shadow-sm" placeholder="Nhập tên hoặc số điện thoại..." value="@ViewBag.SearchString" />
                </div>

                <div class="col-md-3">
                    <label class="form-label fw-bold text-secondary small mb-2"><i class="bi bi-funnel text-warning me-1"></i> Trạng thái đơn</label>
                    <select name="statusFilter" class="form-select form-select-lg border-0 shadow-sm">
                        <option value="">-- Tất cả trạng thái --</option>
                        <option value="Chờ" selected="@(ViewBag.StatusFilter?.Contains("Chờ") ?? false)">Chờ duyệt</option>
                        <option value="Duyệt" selected="@(ViewBag.StatusFilter?.Contains("Duyệt") ?? false)">Đang đá / Đã duyệt</option>
                        <option value="Hoàn" selected="@(ViewBag.StatusFilter?.Contains("Hoàn") ?? false)">Đã thanh toán</option>
                        <option value="Hủy" selected="@(ViewBag.StatusFilter?.Contains("Hủy") ?? false)">Đã Hủy</option>
                    </select>
                </div>

                <div class="col-md-3 d-flex gap-2">
                    <button type="submit" class="btn btn-primary btn-lg fw-bold shadow-sm flex-grow-1 rounded-3">
                        Lọc Dữ Liệu
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary btn-lg fw-bold shadow-sm rounded-3 px-3" title="Làm mới">
                        <i class="bi bi-arrow-clockwise"></i>
                    </a>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
        <div class="card-body p-0 table-responsive">
            <table class="table align-middle mb-0" style="border-collapse: separate; border-spacing: 0;">
                <thead class="table-light">
                    <tr>
                        <th class="py-3 ps-4 text-uppercase text-muted fw-bold small border-bottom-0">Khách Hàng</th>
                        <th class="py-3 text-uppercase text-muted fw-bold small border-bottom-0">Sân Bóng</th>
                        <th class="py-3 text-uppercase text-muted fw-bold small border-bottom-0 text-center">Thời Gian</th>
                        <th class="py-3 text-uppercase text-muted fw-bold small border-bottom-0 text-end">Tổng Tiền</th>
                        <th class="py-3 text-uppercase text-muted fw-bold small border-bottom-0 text-center">Trạng Thái</th>
                        <th class="py-3 text-center pe-4 text-uppercase text-muted fw-bold small border-bottom-0">Thao Tác</th>
                    </tr>
                </thead>
                <tbody class="border-top-0">
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr class="admin-table-row border-bottom">
                                <td class="ps-4 py-3">
                                    <div class="d-flex align-items-center">
                                        <div class="bg-secondary bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px;">
                                            <i class="bi bi-person-fill text-secondary fs-5"></i>
                                        </div>
                                        <div>
                                            <span class="fw-bold d-block text-dark">@item.CustomerName</span>
                                            <small class="text-muted"><i class="bi bi-telephone-fill small text-primary opacity-75 me-1"></i> @item.CustomerPhone</small>
                                        </div>
                                    </div>
                                </td>
                                <td class="fw-bold text-success py-3">@item.PitchName</td>
                                <td class="py-3 text-center">
                                    <span class="d-block fw-bold text-dark fs-6">@item.BookingDate.ToString("dd/MM/yyyy")</span>
                                    <span class="badge bg-light text-primary border border-primary border-opacity-25 mt-1">@item.StartTime - @item.EndTime</span>
                                </td>
                                <td class="text-end fw-bold text-danger py-3 fs-6">@item.TotalPrice.ToString("N0") <small class="text-muted fw-normal">đ</small></td>
                                <td class="text-center py-3">
                                    @if (item.Status.Contains("0") || item.Status.Contains("Pending") || item.Status.Contains("Chờ"))
                                    {
                                        <span class="badge bg-warning bg-opacity-10 text-warning border border-warning px-3 py-2 rounded-pill"><i class="bi bi-hourglass-split"></i> Chờ duyệt</span>
                                    }
                                    else if (item.Status.Contains("1") || item.Status.Contains("Approved") || item.Status.Contains("Duyệt"))
                                    {
                                        <span class="badge bg-success bg-opacity-10 text-success border border-success px-3 py-2 rounded-pill"><i class="bi bi-check2-circle"></i> Đang đá</span>
                                    }
                                    else if (item.Status.Contains("3") || item.Status.Contains("Completed") || item.Status.Contains("Hoàn"))
                                    {
                                        <span class="badge bg-primary bg-opacity-10 text-primary border border-primary px-3 py-2 rounded-pill"><i class="bi bi-flag-fill"></i> Hoàn thành</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger bg-opacity-10 text-danger border border-danger px-3 py-2 rounded-pill"><i class="bi bi-x-circle"></i> Đã hủy</span>
                                    }
                                </td>
                                <td class="text-center pe-4 py-3">
                                    <div class="d-flex justify-content-center gap-2">
                                        @if (item.Status.Contains("0") || item.Status.Contains("Pending") || item.Status.Contains("Chờ"))
                                        {
                                            <form asp-action="UpdateStatus" method="post" class="m-0" id="form-approve-@item.Id">
                                                <input type="hidden" name="bookingId" value="@item.Id" />
                                                <input type="hidden" name="statusId" value="1" />
                                                <button type="button" onclick="confirmAction('form-approve-@item.Id', 'Xác nhận DUYỆT lịch đặt này?', 'Lịch sẽ được chuyển sang trạng thái Đang đá.')" class="btn btn-sm btn-success fw-bold rounded-pill shadow-sm px-3" title="Duyệt lịch">
                                                    <i class="bi bi-check-lg"></i> Duyệt
                                                </button>
                                            </form>
                                            <form asp-action="UpdateStatus" method="post" class="m-0" id="form-reject-@item.Id">
                                                <input type="hidden" name="bookingId" value="@item.Id" />
                                                <input type="hidden" name="statusId" value="2" />
                                                <button type="button" onclick="confirmAction('form-reject-@item.Id', 'Xác nhận TỪ CHỐI?', 'Khách sẽ bị hủy lịch này!', 'error')" class="btn btn-sm btn-outline-danger fw-bold rounded-pill shadow-sm px-3" title="Từ chối">
                                                    <i class="bi bi-x-lg"></i>
                                                </button>
                                            </form>
                                        }
                                        else if (item.Status.Contains("1") || item.Status.Contains("Approved") || item.Status.Contains("Duyệt"))
                                        {
                                            <a asp-action="Invoice" asp-route-id="@item.Id" class="btn btn-sm btn-primary fw-bold rounded-pill shadow-sm px-3">
                                                <i class="bi bi-receipt"></i> Hóa đơn
                                            </a>
                                            <form asp-action="UpdateStatus" method="post" class="m-0" id="form-complete-@item.Id">
                                                <input type="hidden" name="bookingId" value="@item.Id" />
                                                <input type="hidden" name="statusId" value="3" />
                                                <button type="button" onclick="confirmAction('form-complete-@item.Id', 'Khách đã thanh toán?', 'Hệ thống sẽ hoàn thành hóa đơn này và ghi nhận doanh thu.', 'info', 'Đã thanh toán')" class="btn btn-sm btn-outline-success fw-bold rounded-pill shadow-sm px-3" title="Thu tiền">
                                                    <i class="bi bi-cash-coin"></i> Thu tiền
                                                </button>
                                            </form>
                                        }
                                        else if (item.Status.Contains("3") || item.Status.Contains("Completed") || item.Status.Contains("Hoàn"))
                                        {
                                            <a asp-action="Invoice" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary fw-bold rounded-pill shadow-sm px-3">
                                                <i class="bi bi-eye"></i> Xem Bill
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted fst-italic">
                                <i class="bi bi-inbox fs-1 d-block mb-3 text-secondary opacity-50"></i>
                                <span class="fs-5">Không tìm thấy lịch đặt nào khớp với bộ lọc.</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="quickBookModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header bg-success text-white border-0 p-4">
                <h5 class="modal-title fw-bold fs-4"><i class="bi bi-lightning-charge me-2"></i>Đặt Sân Nhanh</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="Book" method="get">
                <div class="modal-body p-4 text-center">
                    <div class="mb-4 mt-2">
                        <label class="form-label fw-bold text-secondary mb-3">Vui lòng chọn cụm sân muốn đặt:</label>
                        <select name="pitchId" class="form-select form-select-lg bg-light border-0 shadow-sm mx-auto" style="max-width: 90%;" required>
                            <option value="">-- Chọn Sân Bóng --</option>
                            @if (ViewBag.Pitches != null)
                            {
                                foreach (var pitch in ViewBag.Pitches)
                                {
                                    <option value="@pitch.Id">@pitch.Name (@pitch.PricePerHour.ToString("N0")đ/giờ)</option>
                                }
                            }
                        </select>
                    </div>
                </div>
                <div class="modal-footer bg-light border-0 p-3 d-flex justify-content-center gap-2">
                    <button type="button" class="btn btn-light fw-bold rounded-pill border px-4 py-2" data-bs-dismiss="modal">Hủy bỏ</button>
                    <button type="submit" class="btn btn-success fw-bold rounded-pill shadow-sm px-5 py-2">Tiếp tục <i class="bi bi-arrow-right ms-1"></i></button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function confirmAction(formId, title, text, icon = 'warning', confirmBtnText = 'Xác nhận') {
            Swal.fire({
                title: title,
                text: text,
                icon: icon,
                showCancelButton: true,
                confirmButtonColor: '#198754',
                cancelButtonColor: '#6c757d',
                confirmButtonText: confirmBtnText,
                cancelButtonText: 'Hủy bỏ',
                shape: 'pill'
            }).then((result) => {
                if (result.isConfirmed) {
                    document.getElementById(formId).submit();
                }
            })
        }
    </script>
}