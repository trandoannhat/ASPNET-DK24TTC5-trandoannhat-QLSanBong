@model QLSanBong.Application.DTOs.Account.UserProfileDto

@{
    ViewData["Title"] = "Hồ sơ cá nhân";
    var defaultAvatar = "https://ui-avatars.com/api/?name=" + (Model?.FullName ?? "User") + "&background=random";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0">
                    <h3 class="fw-bold text-primary"><i class="bi bi-person-lines-fill me-2"></i> Hồ sơ cá nhân</h3>
                </div>
                <div class="card-body p-4">

                   

                    <form asp-action="UpdateInfo" method="post" enctype="multipart/form-data">
                        <div class="text-center mb-4">
                            <img id="avatarPreview"
                                 src="@(string.IsNullOrEmpty(Model?.AvatarUrl) ? defaultAvatar : Model.AvatarUrl)"
                                 class="rounded-circle shadow"
                                 style="width: 120px; height: 120px; object-fit: cover;"
                                 alt="Avatar" />
                            <div class="mt-3">
                                <label for="avatarFile" class="btn btn-sm btn-outline-secondary rounded-pill fw-bold px-3">
                                    <i class="bi bi-camera"></i> Đổi ảnh đại diện
                                </label>
                                <input type="file" id="avatarFile" name="avatarFile" class="d-none" accept="image/*" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Địa chỉ Email (Không thể đổi)</label>
                            <input type="text" class="form-control bg-light" value="@Model?.Email" readonly />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Họ và Tên</label>
                            <input type="text" name="FullName" class="form-control" value="@Model?.FullName" required />
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold">Số điện thoại</label>
                            <input type="text" name="PhoneNumber" class="form-control" value="@Model?.PhoneNumber" />
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-4">
                            <a asp-action="ChangePassword" class="text-decoration-none fw-bold text-danger">
                                <i class="bi bi-shield-lock"></i> Đổi mật khẩu
                            </a>
                            <button type="submit" class="btn btn-primary fw-bold px-4 rounded-pill">Lưu Thay Đổi</button>
                        </div>
                    </form>
                    @section Scripts {
                        <script>
                            // Lắng nghe sự kiện khi người dùng chọn file mới
                            document.getElementById('avatarFile').addEventListener('change', function (event) {
                                const file = event.target.files[0];
                                if (file) {
                                    // Tạo một URL tạm thời từ file vừa chọn và gán thẳng vào src của thẻ img
                                    const previewUrl = URL.createObjectURL(file);
                                    document.getElementById('avatarPreview').src = previewUrl;
                                }
                            });
                        </script>
                    }
                </div>
            </div>
        </div>
    </div>
</div>