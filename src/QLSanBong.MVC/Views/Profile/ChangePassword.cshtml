@model QLSanBong.Application.DTOs.Account.ChangePasswordRequest

@{
    ViewData["Title"] = "Đổi Mật Khẩu";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0">
                    <h3 class="fw-bold text-danger"><i class="bi bi-shield-lock me-2"></i> Đổi mật khẩu</h3>
                </div>
                <div class="card-body p-4">

                    <form asp-action="ChangePassword" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3 fw-bold"></div>

                        <div class="mb-3">
                            <label asp-for="OldPassword" class="form-label fw-semibold">Mật khẩu hiện tại</label>
                            <input asp-for="OldPassword" type="password" class="form-control" placeholder="Nhập mật khẩu cũ" required />
                            <span asp-validation-for="OldPassword" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="NewPassword" class="form-label fw-semibold">Mật khẩu mới</label>
                            <input asp-for="NewPassword" type="password" class="form-control" placeholder="Mật khẩu mới (ít nhất 6 ký tự)" required />
                            <span asp-validation-for="NewPassword" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="ConfirmPassword" class="form-label fw-semibold">Xác nhận mật khẩu mới</label>
                            <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Nhập lại mật khẩu mới" required />
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-4">
                            <a asp-action="Index" class="text-decoration-none fw-bold text-muted">
                                <i class="bi bi-arrow-left"></i> Quay lại hồ sơ
                            </a>
                            <button type="submit" class="btn btn-danger fw-bold px-4 rounded-pill">Đổi Mật Khẩu</button>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}