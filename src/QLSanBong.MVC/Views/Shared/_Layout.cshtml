<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - QLSanBong</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="bg-light">
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-white border-bottom shadow-sm mb-4">
            <div class="container">
                <a class="navbar-brand fw-bold text-success" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-tsunami"></i> QLSanBong Sports
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Trang Chủ</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Pitch" asp-action="Index">Danh Sách Sân Bóng</a>
                        </li>

                        @* KHI ĐÃ ĐĂNG NHẬP & CÓ QUYỀN MỚI HIỆN MENU ADMIN *@
                        @if (User.Identity != null && User.Identity.IsAuthenticated && (User.IsInRole("Admin") || User.IsInRole("PitchAdmin")))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-danger fw-bold" href="#" id="adminDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-shield-lock"></i> Quản Trị
                                </a>
                                <ul class="dropdown-menu" aria-labelledby="adminDropdown">
                                    <li>
                                        <a class="dropdown-item fw-bold text-primary" asp-controller="Dashboard" asp-action="Index">
                                            <i class="bi bi-speedometer2 me-2"></i> Tổng Quan (Dashboard)
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="AdminBooking" asp-action="Index">
                                            <i class="bi bi-list-check me-2"></i>Danh Sách Lịch Đặt
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item fw-bold text-success" asp-controller="AdminBooking" asp-action="Calendar">
                                            <i class="bi bi-calendar-week me-2"></i>Lịch Biểu Sân Bóng
                                        </a>
                                    </li>
                                    <li><a class="dropdown-item" asp-controller="AdminPitch" asp-action="Index"><i class="bi bi-grid me-2"></i>Quản Lý Sân Bóng</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" asp-controller="AdminService" asp-action="Index"><i class="bi bi-cup-straw me-2"></i>Quản Lý Dịch Vụ</a></li>
                                </ul>
                            </li>
                        }
                    </ul>

                    <ul class="navbar-nav">
                        @* HIỂN THỊ TRẠNG THÁI ĐĂNG NHẬP/ĐĂNG KÝ *@
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-primary fw-bold" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-person-circle"></i> Chào, @User.Identity.Name
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">

                                  
                                    <li><a class="dropdown-item" asp-controller="Profile" asp-action="Index"><i class="bi bi-person me-2"></i>Hồ sơ cá nhân</a></li>

                                    <li><a class="dropdown-item" asp-controller="Pitch" asp-action="MyBookings"><i class="bi bi-clock-history me-2"></i>Lịch sử đặt sân</a></li>

                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item text-danger" asp-controller="Auth" asp-action="Logout"><i class="bi bi-box-arrow-right me-2"></i>Đăng xuất</a></li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Auth" asp-action="Login">Đăng nhập</a>
                            </li>
                            <li class="nav-item ms-2">
                                <a class="btn btn-success rounded-pill px-3" asp-controller="Auth" asp-action="Register">Đăng ký</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
       

        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-auto py-4 bg-white">
        <div class="container text-center">
            &copy; @DateTime.Now.Year - DNhat Sports - Thiết kế bởi DNhat
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        const Toast = Swal.mixin({
            toast: true,
            position: 'top-end',
            showConfirmButton: false,
            timer: 3000,
            timerProgressBar: true,
            didOpen: (toast) => {
                toast.addEventListener('mouseenter', Swal.stopTimer)
                toast.addEventListener('mouseleave', Swal.resumeTimer)
            }
        });

        // Bắt TempData bằng Razor
        @if (TempData["SuccessMessage"] != null)
        {
                <text>
                Toast.fire({
                    icon: 'success',
                    title: '@TempData["SuccessMessage"]'
                });
                </text>
        }

        @if (TempData["ErrorMessage"] != null)
        {
                <text>
                Toast.fire({
                    icon: 'error',
                    title: '@TempData["ErrorMessage"]'
                });
                </text>
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>