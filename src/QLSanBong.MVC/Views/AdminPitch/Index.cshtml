@model IEnumerable<QLSanBong.MVC.Models.PitchViewModel>
@{
    ViewData["Title"] = "Quản Lý Sân Bóng";
}

@section Styles {
    <style>
        .admin-table-row {
            transition: background-color 0.2s ease;
        }

            .admin-table-row:hover {
                background-color: #f8f9fa;
            }
    </style>
}

<div class="container-fluid mt-4 mb-5">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
        <h2 class="fw-bold text-uppercase mb-0 text-dark">
            <span class="bg-success bg-opacity-10 text-success p-2 rounded-3 me-2">
                <i class="bi bi-grid-3x3-gap-fill"></i>
            </span>
            Quản Lý Sân Bóng
        </h2>
        <a asp-action="Create" class="btn btn-success fw-bold shadow-sm rounded-pill px-4 py-2">
            <i class="bi bi-plus-circle me-1"></i> Thêm Sân Mới
        </a>
    </div>

   

    <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
        <div class="card-body p-0 table-responsive">
            <table class="table align-middle mb-0" style="border-collapse: separate; border-spacing: 0;">
                <thead class="table-light">
                    <tr>
                        <th class="py-3 ps-4 text-uppercase text-muted fw-bold small border-bottom-0">Tên Sân</th>
                        <th class="py-3 text-uppercase text-muted fw-bold small border-bottom-0 text-center">Quy Mô</th>
                        <th class="py-3 text-uppercase text-muted fw-bold small border-bottom-0 text-end">Giá Thuê / Giờ</th>
                        <th class="py-3 text-center pe-4 text-uppercase text-muted fw-bold small border-bottom-0">Hành Động</th>
                    </tr>
                </thead>
                <tbody class="border-top-0">
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr class="admin-table-row border-bottom">
                                <td class="ps-4 py-3 fw-bold text-dark fs-6">
                                    <i class="bi bi-geo-alt text-success me-1"></i> @item.Name
                                </td>
                                <td class="py-3 text-center">
                                    <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 rounded-pill px-3 py-1">@item.PitchType</span>
                                </td>
                                <td class="py-3 text-end fw-bold text-danger fs-6">
                                    @item.PricePerHour.ToString("N0") <small class="text-muted fw-normal">đ</small>
                                </td>
                                <td class="text-center pe-4 py-3">
                                    <div class="d-flex justify-content-center gap-2">
                                        <a asp-controller="AdminBooking" asp-action="Book" asp-route-pitchId="@item.Id" class="btn btn-sm btn-outline-success fw-bold rounded-pill px-3 shadow-sm" title="Đặt lịch hộ khách">
                                            <i class="bi bi-calendar-plus me-1"></i> Đặt Lịch
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning fw-bold rounded-pill px-3 shadow-sm" title="Chỉnh sửa sân">
                                            <i class="bi bi-pencil-square me-1"></i> Sửa
                                        </a>
                                        <form asp-action="Delete" method="post" class="m-0" onsubmit="return confirm('Xác nhận xóa sân bóng này? Dữ liệu lịch đặt liên quan có thể bị ảnh hưởng.');">
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger fw-bold rounded-pill px-3 shadow-sm" title="Xóa sân">
                                                <i class="bi bi-trash3 me-1"></i> Xóa
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5">
                                <i class="bi bi-inbox text-muted opacity-50" style="font-size: 4rem;"></i>
                                <h5 class="fw-bold mt-3 text-dark">Chưa có dữ liệu sân bóng</h5>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>